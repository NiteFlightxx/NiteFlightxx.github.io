---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { knowledgeCategoryZh } from '../../lib/taxonomy';

export async function getStaticPaths() {
  const entries = await getCollection('knowledge', (entry) => !entry.data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const baseURL = import.meta.env.BASE_URL;

// Localize the ISO date the same way the SPA loader does (content.ts formatZhDate).
function formatZhDate(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
}
---

<ArticleLayout
  title={entry.data.title}
  excerpt={entry.data.excerpt}
  category={knowledgeCategoryZh(entry.data.category)}
  date={formatZhDate(entry.data.date)}
  readTime={entry.data.readTime}
  tags={entry.data.tags}
  headings={headings}
  backHref={`${baseURL}#knowledge`}
  backLabel="返回知识库"
  lang="zh"
>
  <Content />
</ArticleLayout>
